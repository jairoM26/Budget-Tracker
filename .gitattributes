# Enforce consistent line endings across all operating systems.
# Windows uses CRLF by default. Linux containers and CI runners use LF.
# Without this file, scripts committed on Windows will fail in containers and CI.

* text=auto eol=lf

*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.env text eol=lf
*.env.example text eol=lf
Dockerfile text eol=lf
*.prisma text eol=lf
*.md text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
