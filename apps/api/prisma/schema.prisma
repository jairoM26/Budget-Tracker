generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PendingTransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmailProvider {
  IMAP
  GMAIL
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  currency     String   @default("USD")
  createdAt    DateTime @default(now())

  categories          Category[]
  transactions        Transaction[]
  budgets             Budget[]
  recurringRules      RecurringRule[]
  refreshTokens       RefreshToken[]
  emailConnections    EmailConnection[]
  emailLogs           EmailLog[]
  pendingTransactions PendingTransaction[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id     String           @id @default(uuid())
  userId String
  name   String
  color  String           @default("#6366f1")
  icon   String           @default("tag")
  type   TransactionType?

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  budgetCategories    BudgetCategory[]
  recurringRules      RecurringRule[]
  pendingTransactions PendingTransaction[]

  @@index([userId])
}

model Budget {
  id         String  @id @default(uuid())
  userId     String
  year       Int
  month      Int
  totalLimit Decimal @db.Decimal(12, 2)

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetCategories BudgetCategory[]

  @@unique([userId, year, month])
}

model BudgetCategory {
  id          String  @id @default(uuid())
  budgetId    String
  categoryId  String
  limitAmount Decimal @db.Decimal(12, 2)

  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([budgetId, categoryId])
}

model Transaction {
  id              String          @id @default(uuid())
  userId          String
  categoryId      String
  amount          Decimal         @db.Decimal(12, 2)
  type            TransactionType
  description     String
  notes           String?
  date            DateTime
  recurringRuleId String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])
  recurringRule RecurringRule? @relation(fields: [recurringRuleId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@index([categoryId])
}

model RecurringRule {
  id          String             @id @default(uuid())
  userId      String
  categoryId  String
  amount      Decimal            @db.Decimal(12, 2)
  type        TransactionType
  description String
  frequency   RecurringFrequency
  nextDue     DateTime
  endDate     DateTime?
  active      Boolean            @default(true)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([userId, active])
}

model EmailConnection {
  id              String        @id @default(uuid())
  userId          String
  provider        EmailProvider
  email           String
  encryptedCreds  String        @db.Text
  active          Boolean       @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime      @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanRules ScanRule[]

  @@index([userId])
}

model ScanRule {
  id                String   @id @default(uuid())
  emailConnectionId String
  subjectFilter     String
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  emailConnection EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)
  emailLogs       EmailLog[]

  @@index([emailConnectionId])
}

model EmailLog {
  id           String    @id @default(uuid())
  userId       String
  scanRuleId   String?
  fromAddress  String
  subject      String?
  bodyText     String?   @db.Text
  processedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanRule            ScanRule?           @relation(fields: [scanRuleId], references: [id], onDelete: SetNull)
  pendingTransactions PendingTransaction[]

  @@index([userId])
  @@index([createdAt])
}

model PendingTransaction {
  id            String                   @id @default(uuid())
  userId        String
  emailLogId    String?
  amount        Decimal?                 @db.Decimal(12, 2)
  type          TransactionType?
  description   String?
  merchant      String?
  date          DateTime?
  categoryId    String?
  status        PendingTransactionStatus @default(PENDING)
  confidence    Decimal                  @db.Decimal(3, 2)
  aiRawResponse String?                  @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime                 @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLog EmailLog? @relation(fields: [emailLogId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([createdAt])
}
